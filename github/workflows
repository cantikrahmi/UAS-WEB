name: Deploy Website CatCare to VPS

on:
  push:
    branches:
      - main  # Memicu otomatisasi setiap ada push ke branch main

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout Repository Code
      uses: actions/checkout@v3

    - name: Deploy to VPS via SSH
      uses: appleboy/ssh-action@v1.0.3
      with:
        host: ${{ secrets.VPS_HOST }}       # IP Address VPS kamu
        username: cantikrahmi               # Username SSH kamu
        key: ${{ secrets.SSH_PRIVATE_KEY }} # SSH Private Key untuk login otomatis
        script: |
          cd /home/cantikrahmi/UAS-WEB
          git pull origin main
          # Jika aplikasi menggunakan Docker container, ia akan merestart otomatis
          docker restart $(docker ps -q -l) || true
